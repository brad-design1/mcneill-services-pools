---
import Layout from "../layouts/Layout.astro";
---

<Layout title="McNeill Services — Affordable Pools & Back Patios | Houston">
  <!-- Hero -->
  <section class="relative flex min-h-[85vh] items-center justify-center bg-navy text-white overflow-hidden">
    <!-- Video Background -->
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 h-full w-full object-cover"
    >
      <source src="/videos/hero-bg.mp4" type="video/mp4" />
    </video>
    <!-- Dark Overlay -->
    <div class="absolute inset-0 bg-navy/70"></div>
    <div class="relative z-10 mx-auto max-w-5xl px-6 py-20 text-center">
      <!-- Trust Badge -->
      <div class="mb-8 inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm backdrop-blur-sm">
        <svg class="h-5 w-5 text-gold" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        <span class="text-white/90">Licensed & Insured · Family Owned</span>
      </div>

      <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl">
        Affordable Pools &<br class="hidden sm:block" /> Back Patios
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-white/90 sm:text-xl">
        Quality craftsmanship at honest prices. Custom pools, spas, patios, and outdoor living 
        spaces — built to last, priced to fit your budget.
      </p>
      
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/contact"
          class="w-full rounded-xl bg-gold px-10 py-4 text-lg font-semibold text-navy shadow-lg transition hover:bg-gold-light hover:shadow-xl sm:w-auto"
        >
          Get Your Free Quote
        </a>
        <a
          href="tel:+19365200872"
          class="w-full rounded-xl border-2 border-white/30 px-10 py-4 text-lg font-semibold transition hover:bg-white/10 sm:w-auto"
        >
          (936) 520-0872
        </a>
      </div>

      <!-- Stats Row -->
      <div class="mt-16 grid grid-cols-3 gap-4 border-t border-white/10 pt-10">
        <div>
          <div class="text-3xl font-bold text-gold sm:text-4xl">500+</div>
          <div class="mt-1 text-sm text-white/60">Pools Built</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-gold sm:text-4xl">15+</div>
          <div class="mt-1 text-sm text-white/60">Years Experience</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-gold sm:text-4xl">100%</div>
          <div class="mt-1 text-sm text-white/60">Satisfaction</div>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="bg-warm-white py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid items-center gap-12 md:grid-cols-2">
        <div>
          <span class="text-sm font-semibold uppercase tracking-wider text-pool-blue">About Us</span>
          <h2 class="mt-2 text-3xl font-bold text-navy sm:text-4xl">
            Welcome to McNeill Services
          </h2>
          <p class="mt-4 text-lg text-charcoal/80">
            We're a family-owned pool and patio company serving the greater Houston area. 
            What started as a passion for creating beautiful outdoor spaces has grown into 
            a trusted name in custom pool construction and backyard design.
          </p>
          <p class="mt-4 text-charcoal/70">
            At McNeill Services, we believe every family deserves a backyard oasis — without 
            the luxury price tag. We work directly with you to design and build pools and patios 
            that fit your lifestyle and budget. No pushy sales tactics. No hidden fees. Just 
            honest work and beautiful results.
          </p>
          <a
            href="/contact"
            class="mt-8 inline-flex items-center gap-2 font-semibold text-pool-blue transition hover:text-navy"
          >
            Let's talk about your project
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] overflow-hidden rounded-2xl">
            <img
              src="/images/about-pool-landscape.png"
              alt="Family enjoying their custom pool"
              class="h-full w-full object-cover object-center"
            />
          </div>
          <!-- Floating badge -->
          <div class="absolute -bottom-6 -right-6 rounded-xl bg-navy p-4 text-white shadow-lg">
            <div class="text-2xl font-bold">15+</div>
            <div class="text-sm text-white/70">Years of<br/>Excellence</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="bg-warm-white py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center">
        <span class="text-sm font-semibold uppercase tracking-wider text-pool-blue">What We Offer</span>
        <h2 class="mt-2 text-3xl font-bold text-navy sm:text-4xl">Our Services</h2>
        <p class="mx-auto mt-4 max-w-2xl text-charcoal/70">
          From custom pool design to complete backyard transformations, we handle every detail 
          of your outdoor project.
        </p>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Pool Construction -->
        <div class="group rounded-2xl border border-stone/20 bg-white p-8 shadow-sm transition hover:shadow-lg">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-pool-blue/10 text-pool-blue">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy">Custom Pools</h3>
          <p class="mt-3 text-charcoal/70">
            Gunite and fiberglass pools designed to fit your space. Includes excavation, 
            plumbing, finishing, and decking.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-charcoal/60">
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-pool-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Free design consultation
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-pool-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Energy-efficient equipment
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-pool-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Warranty included
            </li>
          </ul>
        </div>

        <!-- Spas & Water Features -->
        <div class="group rounded-2xl border border-stone/20 bg-white p-8 shadow-sm transition hover:shadow-lg">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-pool-blue/10 text-pool-blue">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy">Spas & Water Features</h3>
          <p class="mt-3 text-charcoal/70">
            Attached or standalone spas, waterfalls, fountains, and bubblers to elevate 
            your pool experience.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-charcoal/60">
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-pool-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Custom spa designs
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-pool-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              LED lighting options
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-pool-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Automation systems
            </li>
          </ul>
        </div>

        <!-- Back Patios -->
        <div class="group rounded-2xl border border-stone/20 bg-white p-8 shadow-sm transition hover:shadow-lg">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-pool-blue/10 text-pool-blue">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy">Back Patios</h3>
          <p class="mt-3 text-charcoal/70">
            Flagstone, travertine, stamped concrete, and pavers. Beautiful surfaces that 
            complement your pool and home.
          </p>
          <ul class="mt-4 space-y-2 text-sm text-charcoal/60">
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-pool-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Multiple material options
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-pool-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Cool deck coatings
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-pool-blue" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Drainage solutions
            </li>
          </ul>
        </div>

        <!-- Outdoor Kitchens -->
        <div class="group rounded-2xl border border-stone/20 bg-white p-8 shadow-sm transition hover:shadow-lg">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-pool-blue/10 text-pool-blue">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy">Outdoor Kitchens</h3>
          <p class="mt-3 text-charcoal/70">
            Built-in grills, countertops, sinks, refrigeration, and bar seating for the 
            ultimate entertaining space.
          </p>
        </div>

        <!-- Fire Features -->
        <div class="group rounded-2xl border border-stone/20 bg-white p-8 shadow-sm transition hover:shadow-lg">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-pool-blue/10 text-pool-blue">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy">Fire Pits & Features</h3>
          <p class="mt-3 text-charcoal/70">
            Gas and wood-burning fire pits, fire bowls, and fireplaces that extend your 
            outdoor season year-round.
          </p>
        </div>

        <!-- Pergolas -->
        <div class="group rounded-2xl border border-stone/20 bg-white p-8 shadow-sm transition hover:shadow-lg">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-pool-blue/10 text-pool-blue">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy">Pergolas & Shade</h3>
          <p class="mt-3 text-charcoal/70">
            Custom pergolas, pavilions, and shade structures that provide relief from the 
            Texas sun while adding style.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section id="why-us" class="bg-navy py-20 text-white">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center">
        <span class="text-sm font-semibold uppercase tracking-wider text-gold">The McNeill Difference</span>
        <h2 class="mt-2 text-3xl font-bold sm:text-4xl">Why Choose Us</h2>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-pool-blue/20">
            <svg class="h-8 w-8 text-pool-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold">Honest Pricing</h3>
          <p class="mt-2 text-sm text-white/70">
            Transparent quotes with no hidden fees. What we quote is what you pay.
          </p>
        </div>

        <div class="text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-pool-blue/20">
            <svg class="h-8 w-8 text-pool-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold">Family Owned</h3>
          <p class="mt-2 text-sm text-white/70">
            Work directly with owners who care about your project, not a sales team.
          </p>
        </div>

        <div class="text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-pool-blue/20">
            <svg class="h-8 w-8 text-pool-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold">Licensed & Insured</h3>
          <p class="mt-2 text-sm text-white/70">
            Fully licensed, bonded, and insured for your complete peace of mind.
          </p>
        </div>

        <div class="text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-pool-blue/20">
            <svg class="h-8 w-8 text-pool-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold">On-Time Delivery</h3>
          <p class="mt-2 text-sm text-white/70">
            We stick to timelines and keep you updated every step of the way.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section id="testimonials" class="bg-warm-white py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center">
        <span class="text-sm font-semibold uppercase tracking-wider text-pool-blue">Testimonials</span>
        <h2 class="mt-2 text-3xl font-bold text-navy sm:text-4xl">What Our Clients Say</h2>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-3">
        <!-- Testimonial 1 -->
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <div class="mb-4 flex text-gold">
            {[...Array(5)].map(() => (
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-charcoal/80">
            "McNeill Services built our dream pool and the entire experience was fantastic. 
            Fair price, great communication, and the finished product is beautiful. Highly recommend!"
          </p>
          <div class="mt-6 flex items-center gap-3">
            <div class="h-10 w-10 rounded-full bg-navy/10"></div>
            <div>
              <div class="font-semibold text-navy">Sarah M.</div>
              <div class="text-sm text-charcoal/60">Katy, TX</div>
            </div>
          </div>
        </div>

        <!-- Testimonial 2 -->
        <div class="rounded-2xl bg-white p-8 shadow-sm">
          <div class="mb-4 flex text-gold">
            {[...Array(5)].map(() => (
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-charcoal/80">
            "We got quotes from 5 different pool companies and McNeill was the most honest and 
            straightforward. No upselling, no games. Our patio turned out even better than we imagined."
          </p>
          <div class="mt-6 flex items-center gap-3">
            <div class="h-10 w-10 rounded-full bg-navy/10"></div>
            <div>
              <div class="font-semibold text-navy">James & Linda R.</div>
              <div class="text-sm text-charcoal/60">Sugar Land, TX</div>
