---
const navLinks = [
  { href: "#services", label: "Services" },
  { href: "#about", label: "About" },
  { href: "#why-us", label: "Why Us" },
  { href: "#testimonials", label: "Reviews" },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-navy/10 bg-white/95 backdrop-blur-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6">
    <!-- Logo - Large & Overlapping -->
    <a href="/" class="relative z-60 -mb-24 sm:-mb-28 md:-mb-32">
      <div class="relative">
        <img
          src="/images/logo.jpeg"
          alt="McNeill Services"
          width="180"
          height="180"
          class="h-32 w-32 rounded-full border-4 border-white shadow-2xl sm:h-40 sm:w-40 md:h-48 md:w-48"
        />
        <!-- Optional: Ring accent -->
        <div class="absolute inset-0 rounded-full ring-4 ring-navy/10"></div>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-semibold uppercase tracking-wide text-charcoal transition hover:text-pool-blue"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Phone CTA -->
    <a
      href="tel:+19365200872"
      class="flex items-center gap-2 rounded-lg bg-navy px-5 py-3 text-sm font-semibold text-white transition hover:bg-navy-light"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      <span class="hidden sm:inline">(936) 520-0872</span>
      <span class="sm:hidden">Call</span>
    </a>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="ml-2 rounded-lg p-2 text-charcoal md:hidden"
      aria-label="Open menu"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-menu" class="hidden border-t border-navy/10 bg-white px-4 py-4 md:hidden">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="block py-2 font-medium text-charcoal transition hover:text-pool-blue"
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
