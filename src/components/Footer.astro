---
const currentYear = new Date().getFullYear();
---

<footer class="bg-navy text-white">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6">
    <div class="grid gap-12 md:grid-cols-3">
      <!-- Company Info -->
      <div>
        <div class="flex items-center gap-3">
          <img
            src="/images/logo.jpeg"
            alt="McNeill Services"
            width="56"
            height="56"
            class="rounded-full"
          />
          <div>
            <span class="text-xl font-bold">McNeill Services</span>
            <span class="block text-sm text-pool-blue-light">Affordable Pools & Patios</span>
          </div>
        </div>
        <p class="mt-4 text-sm text-white/70">
          Quality craftsmanship at honest prices. Serving the Houston area with custom pools, 
          spas, patios, and outdoor living spaces.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gold">Quick Links</h3>
        <ul class="mt-4 space-y-2">
          <li><a href="#services" class="text-sm text-white/70 transition hover:text-white">Our Services</a></li>
          <li><a href="#about" class="text-sm text-white/70 transition hover:text-white">About Us</a></li>
          <li><a href="#why-us" class="text-sm text-white/70 transition hover:text-white">Why Choose Us</a></li>
          <li><a href="#testimonials" class="text-sm text-white/70 transition hover:text-white">Reviews</a></li>
          <li><a href="/contact" class="text-sm text-white/70 transition hover:text-white">Contact</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gold">Contact Us</h3>
        <ul class="mt-4 space-y-3">
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 text-pool-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+18325551234" class="text-sm text-white/70 transition hover:text-white">(832) 555-1234</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-5 w-5 text-pool-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@mcneillservicespools.com" class="text-sm text-white/70 transition hover:text-white">info@mcneillservicespools.com</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="mt-0.5 h-5 w-5 text-pool-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm text-white/70">Serving Greater Houston Area</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 border-t border-white/10 pt-8 text-center">
      <p class="text-sm text-white/50">
        © {currentYear} McNeill Services. All rights reserved. Licensed & Insured.
      </p>
    </div>
  </div>
</footer>
