---
const phoneNumber = "9365200872";
const phoneFormatted = "(936) 520-0872";
---

<!-- Phone Modal -->
<div id="phone-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/50 backdrop-blur-sm">
  <div class="mx-4 w-full max-w-sm rounded-2xl bg-white p-6 shadow-2xl">
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-pool-blue/10">
        <svg class="h-8 w-8 text-pool-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-navy">Contact McNeill Services</h3>
      <p class="mt-2 text-charcoal/70">{phoneFormatted}</p>
    </div>

    <div class="mt-6 flex flex-col gap-3">
      <a
        href={`tel:+1${phoneNumber}`}
        class="flex items-center justify-center gap-2 rounded-xl bg-navy py-4 font-semibold text-white transition hover:bg-navy-light"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call Now
      </a>
      <a
        href={`sms:+1${phoneNumber}`}
        class="flex items-center justify-center gap-2 rounded-xl bg-pool-blue py-4 font-semibold text-white transition hover:bg-pool-blue-light"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        Send a Text
      </a>
    </div>

    <button
      id="close-phone-modal"
      class="mt-4 w-full py-2 text-center text-sm font-medium text-charcoal/60 transition hover:text-charcoal"
    >
      Cancel
    </button>
  </div>
</div>

<script>
  // Get all phone links and convert to modal triggers
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('phone-modal');
    const closeBtn = document.getElementById('close-phone-modal');
    
    // Find all tel: links and convert them to modal triggers
    document.querySelectorAll('a[href^="tel:"]').forEach(link => {
      // Skip links inside the modal itself
      if (link.closest('#phone-modal')) return;
      
      link.addEventListener('click', (e) => {
        e.preventDefault();
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
      });
    });

    // Close modal on button click
    closeBtn?.addEventListener('click', () => {
      modal?.classList.add('hidden');
      modal?.classList.remove('flex');
    });

    // Close modal on backdrop click
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
    });

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
      }
    });
  });
</script>
